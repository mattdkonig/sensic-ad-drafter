 "chief-usa": [
  {
   "id": "chief-usa-carnivore-biltong-statics",
   "uploaded": false,
   "concept": "Carnivore Biltong Statics",
   "objective": "",
   "type": "",
   "num_creatives": null,
   "primary_text": "Introducing the ultimate carnivore snack for your primal lifestyle: Carnivore Biltong, crafted from 100% organic, grass-fed, and grass-finished beef.  We've stripped away all the unnecessary additives to bring you a pure, protein-packed snack that's as simple as it is satisfying.   Made with just beef, salt, and vinegar, our biltong is naturally more tender and healthier than jerky, without any herbs, spices, or preservatives.  Each 30g serving delivers a powerful protein punch of 14.1g, supporting your muscles and keeping you fueled throughout the day. With zero carbs and only 1.9g of fat per serving, it's the perfect snack for those following a carnivore or low-carb diet.  🥩 100% Organic Grass-Fed Beef 🥩 High in Protein, Zero Carbs 🥩 No Preservatives or Additives 🥩 Gluten and Dairy Free 🥩 FODMAP Friendly 🥩 Halal Certified  Our Carnivore Biltong is ideal for on-the-go snacking, pre or post-workout fuel, or as a satisfying addition to your carnivore meal plan.   Packed in convenient 30g bags, it's ready to eat whenever and wherever your primal instincts kick in.",
   "headline": "The Ultimate Carnivore Snack",
   "cta": "",
   "landing_url": "https://wearechief.com/en-us/products/air-dried-steak-carnivore?_pos=1&_psq=carnivore&_ss=e&_v=1.0",
   "campaign": null,
   "adset_hint": null,
   "creatives_folder": null
  },
  {
   "id": "chief-usa-lemon-pepper-biltong",
   "uploaded": false,
   "concept": "Lemon Pepper Biltong",
   "objective": "",
   "type": "",
   "num_creatives": null,
   "primary_text": "Introducing the ultimate grass-fed snack for your active lifestyle: Grass-fed Biltong - Lemon Pepper, crafted from 100% grass-fed, grass-finished Australian beef. We've stripped away all the unnecessary additives to bring you a pure, protein-packed snack that's as zesty as it is satisfying. Made with clean ingredients and no preservatives, our biltong is naturally more tender and healthier than jerky, and far lower in sugar. Each 2oz serving delivers as much protein as 2 eggs, supporting your muscles and keeping you fueled throughout the day. With zero sugar and low carbs, it's the perfect snack for those following keto, paleo, or low-carb diets. 🍋 Zesty Lemon Pepper Flavor - Citrus brightness with a bold peppery kick 🥩 100% Grass-Fed Australian Beef - Premium cattle that roam freely their whole lives 🥩 High Protein, Low Carb - Fuel your body without the sugar crash 🥩 No Preservatives or Additives - Just clean, real ingredients 🥩 Gluten and Dairy Free - Suitable for multiple dietary needs 🥩 FODMAP Friendly - Easy on sensitive digestion Our Lemon Pepper Biltong is ideal for on-the-go snacking, pre or post-workout fuel, or as a satisfying addition to your meal plan. Packed in convenient 2oz bags, it's ready to eat whenever and wherever your cravings for something savory and clean kick in. Like jerky, but better. Slow air dried for tenderness and thinly sliced for the perfect texture.",
   "headline": "The Ultimate Grass-Fed Snack with a Zesty Twist",
   "cta": "",
   "landing_url": "https://us.wearechief.com/collections/organic-biltong/products/air-dried-steak-lemon-pepper",
   "campaign": null,
   "adset_hint": null,
   "creatives_folder": null
  },
  {
   "id": "chief-usa-beef-liver-iron-effectiveness",
   "uploaded": false,
   "concept": "Beef Liver Iron Effectiveness",
   "objective": "",
   "type": "",
   "num_creatives": null,
   "primary_text": "Struggling with fatigue despite taking iron supplements?   The problem might be synthetic iron your body can't properly absorb.   Chief Beef Liver Capsules contains heme iron - the most bioavailable form that may support absorption up to 5 times better than synthetic alternatives. Plus you get essential co-factors like B12, folate, and vitamin A working together as nature intended.  ✅ Grass-fed and grass-finished Australian beef liver ✅ Heme iron for superior absorption ✅ No synthetic binders or fillers ✅ Gentle on your digestive system ✅ Freeze-dried to preserve nutrients  Stop fighting your gut with synthetic iron.   Get the nutrition your ancestors thrived on - without having to eat liver.",
   "headline": "Your iron supplement not working? Try nature's original",
   "cta": "",
   "landing_url": "https://wearechief.com/products/organic-beef-liver-120-capsules",
   "campaign": null,
   "adset_hint": null,
   "creatives_folder": "https://drive.google.com/drive/folders/13LmG2HMTCZoZsHhdNXl74mbpEPkS68VA?usp=drive_link"
